CREATE VIEW vista_ventas_clientes AS
SELECT v.numero_ticket, c.nombre, c.apellido
FROM ventas v
JOIN clientes c ON v.id_cliente = c.id_cliente;

CREATE VIEW vista_productos_proveedores AS
SELECT p.nombre, pr.nombre_drogueria
FROM productos p
JOIN proveedores pr ON p.id_proveedor = pr.id_proveedor;

CREATE VIEW vista_detalle_ventas AS
SELECT v.numero_ticket, p.nombre, d.cantidad
FROM detalle_venta d
JOIN productos p ON d.id_producto = p.id_producto
JOIN ventas v ON d.numero_ticket = v.numero_ticket;

CREATE VIEW vista_ventas_empleados AS
SELECT v.numero_ticket, e.nombre
FROM ventas v
JOIN empleados e ON v.id_empleado = e.id_empleado;

CREATE VIEW vista_clientes_ventas AS
SELECT c.nombre, COUNT(v.numero_ticket) total
FROM clientes c
LEFT JOIN ventas v ON c.id_cliente = v.id_cliente
GROUP BY c.nombre;

DELIMITER //

CREATE FUNCTION total_productos_vendidos(ticket INT) RETURNS INT
BEGIN
DECLARE total INT;
SELECT IFNULL(SUM(cantidad),0) INTO total FROM detalle_venta WHERE numero_ticket = ticket;
RETURN total;
END //

CREATE FUNCTION ventas_cliente(idCliente INT) RETURNS INT
BEGIN
DECLARE total INT;
SELECT COUNT(*) INTO total FROM ventas WHERE id_cliente = idCliente;
RETURN total;
END //

CREATE FUNCTION ventas_empleado(idEmp INT) RETURNS INT
BEGIN
DECLARE total INT;
SELECT COUNT(*) INTO total FROM ventas WHERE id_empleado = idEmp;
RETURN total;
END //

CREATE FUNCTION productos_proveedor(idProv INT) RETURNS INT
BEGIN
DECLARE total INT;
SELECT COUNT(*) INTO total FROM productos WHERE id_proveedor = idProv;
RETURN total;
END //

CREATE FUNCTION promedio_productos(ticket INT) RETURNS DECIMAL(10,2)
BEGIN
DECLARE prom DECIMAL(10,2);
SELECT IFNULL(AVG(cantidad),0) INTO prom FROM detalle_venta WHERE numero_ticket = ticket;
RETURN prom;
END //

CREATE PROCEDURE registrar_cliente(nombreC VARCHAR(50), apellidoC VARCHAR(50))
BEGIN
INSERT INTO clientes(nombre, apellido) VALUES(nombreC, apellidoC);
END //

CREATE PROCEDURE registrar_venta(cliente INT, empleado INT)
BEGIN
INSERT INTO ventas(fecha, id_cliente, id_empleado)
VALUES (CURDATE(), cliente, empleado);
END //

CREATE PROCEDURE registrar_producto(nombreP VARCHAR(50), proveedor INT)
BEGIN
INSERT INTO productos(nombre, id_proveedor)
VALUES(nombreP, proveedor);
END //

CREATE TRIGGER control_cantidad
BEFORE INSERT ON detalle_venta
FOR EACH ROW
BEGIN
IF NEW.cantidad <= 0 THEN
SIGNAL SQLSTATE '45000'
SET MESSAGE_TEXT = 'Cantidad invalida';
END IF;
END //

CREATE TRIGGER fecha_auto
BEFORE INSERT ON ventas
FOR EACH ROW
BEGIN
IF NEW.fecha IS NULL THEN
SET NEW.fecha = CURDATE();
END IF;
END //

CREATE TRIGGER validar_producto
BEFORE INSERT ON productos
FOR EACH ROW
BEGIN
IF NEW.nombre IS NULL THEN
SIGNAL SQLSTATE '45000'
SET MESSAGE_TEXT = 'Producto sin nombre';
END IF;
END //

DELIMITER ;

